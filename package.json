{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "dev": "next dev --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-clean": "node scripts/cf-clean.mjs",
    "preview": "npm run cf-clean && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run cf-clean && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "npm run cf-clean && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "motion": "^12.40.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "openai": "^6.39.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  }
}